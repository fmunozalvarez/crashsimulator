# CrashSimulator startup configuration example
#
# Copy this file to one of these locations:
#   ./crashsimulator.conf
#   $HOME/.crashsimulator/crashsimulator.conf
#   /etc/crashsimulator/crashsimulator.conf
#
# Or pass it explicitly:
#   ./CrashSimulatorV2.sh --config /path/to/crashsimulator.conf --show-config
#
# Precedence:
#   CLI arguments > existing environment variables > this file > built-in defaults
#
# This file is parsed as allowlisted KEY=value entries. It is not sourced as
# shell code. Do not store SYS, RMAN catalog, APEX, wallet, token, or other
# secrets here; use environment variables, wallets, or guided prompts.

ORACLE_SID=orcl1
ORACLE_HOME=/u01/app/oracle/product/19.0.0.0/dbhome_1
ORACLE_BASE=/u01/app/oracle
TNS_ADMIN=/u01/app/oracle/product/19.0.0.0/dbhome_1/network/admin

# Optional RAC/Grid/ASM context.
CRASHSIM_GRID_HOME=/u01/app/19.0.0.0/grid
CRASHSIM_ASM_SID=+ASM1
CRASHSIM_GRID_USER=grid

# CrashSimulator defaults.
CRASHSIM_PDB=CRASHPDB
CRASHSIM_LOG_DIR=/tmp/crashsimulator/crashsimulator_logs
CRASHSIM_SQLPLUS_LOGON='/ as sysdba'
CRASHSIM_AUDIT_RETAIN=yes
CRASHSIM_AUDIT_RETENTION_DAYS=90
CRASHSIM_AUTO_SCORECARD=yes
CRASHSIM_TOPOLOGY_CACHE_TTL_SECONDS=300
CRASHSIM_DISABLE_TOPOLOGY_CACHE=no

# Keep blank by default. Set to YES only in an approved non-production lab
# before non-interactive destructive runs that use --execute --yes.
CRASHSIM_ACCEPT_DESTRUCTIVE_LAB=

# Public-readiness helper defaults.
CRASHSIM_SECRET_SCAN_PATH=.
CRASHSIM_SANITIZE_SOURCE_DIR=.
CRASHSIM_SANITIZE_OUTPUT_DIR=

# Optional RMAN catalog connect string. Prefer an Oracle wallet alias such as
# CRASHSIM_RMAN_CATALOG=/@crashsim_rman_catalog instead of a password here.
CRASHSIM_RMAN_CATALOG=
CRASHSIM_BASELINE_TAG_PREFIX=CSIM_BASE

# Optional APEX/ORDS defaults.
CRASHSIM_ORDS_SERVICE=ords
CRASHSIM_ORDS_CONFIG_DIR=/etc/ords/config
CRASHSIM_ORDS_URL=http://localhost:8080/ords/
CRASHSIM_ORDS_LB_URL=
CRASHSIM_ORDS_DB_POOL=default
CRASHSIM_ORDS_PRIV_HELPER=/usr/local/bin/crashsim_ords_priv
CRASHSIM_APEX_IMAGES_DIR=
CRASHSIM_APEX_SESSION_DRIVER=
CRASHSIM_APEX_SESSION_URL=
CRASHSIM_APEX_SESSION_USERNAME=
CRASHSIM_APEX_SESSION_SUCCESS_SELECTOR=
CRASHSIM_APEX_SESSION_DURATION=90
CRASHSIM_APEX_SESSION_INTERVAL=10
CRASHSIM_APEX_SESSION_HEADLESS=yes

# Optional Autonomous Database defaults. Do not store passwords or wallet
# passphrases here. Set the named environment variables in the shell or secret
# manager before running --adb-readiness-report.
CRASHSIM_ADB_WALLET_DIR=/path/to/Wallet_myadb
CRASHSIM_ADB_CONNECT_ALIAS=myadb_low
CRASHSIM_ADB_CONNECT_DESCRIPTOR=
CRASHSIM_ADB_SERVICE_LEVEL=low
CRASHSIM_ADB_USER=ADMIN
CRASHSIM_ADB_PASSWORD_ENV=CRASHSIM_ADB_PASSWORD
CRASHSIM_ADB_WALLET_PASSWORD_ENV=CRASHSIM_ADB_WALLET_PASSWORD
CRASHSIM_ADB_PYTHON=python3
CRASHSIM_ADB_TLS_MODE=mTLS
CRASHSIM_ADB_OCID=
CRASHSIM_ADB_COMPARTMENT_OCID=
CRASHSIM_ADB_REGION=
CRASHSIM_ADB_OCI_PROFILE=DEFAULT
CRASHSIM_ADB_OCI_CONFIG_FILE=
CRASHSIM_ADB_OCI_AUTH=
CRASHSIM_ADB_APEX_URL=
CRASHSIM_ADB_DATABASE_ACTIONS_URL=
CRASHSIM_ADB_PRIVATE_ENDPOINT=
CRASHSIM_ADB_SCENARIO=
